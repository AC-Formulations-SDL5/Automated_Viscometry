{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv64/Scripts/python.exe",
    "python.linting.enabled": false,
    "python.analysis.typeCheckingMode": "off",
